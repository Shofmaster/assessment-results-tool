{
  "functions": {
    "api/claude.ts": {
      "maxDuration": 300
    }
  },
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "aerogap.com"
        }
      ],
      "destination": "https://www.aerogaptechnologies.com/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "www.aerogap.com"
        }
      ],
      "destination": "https://www.aerogaptechnologies.com/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "aerogaptechnologies.com"
        }
      ],
      "destination": "https://www.aerogaptechnologies.com/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
