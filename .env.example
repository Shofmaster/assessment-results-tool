# =============================================================================
# AeroGap environment variables
# =============================================================================
# Copy to `.env.local` for local dev. NEVER commit real secrets.
#
# Variables live in THREE places at deploy time:
#   1. Frontend / Vercel build  -> VITE_* (this file / Vercel project env)
#   2. Vercel serverless funcs   -> ANTHROPIC_API_KEY (Vercel project env)
#   3. Convex backend            -> set via `npx convex env set NAME value`
# A var set in only one place will make features silently fail. See below.
# -----------------------------------------------------------------------------

# --- Frontend (Vite build / Vercel) -----------------------------------------
# Clerk publishable key (pk_test_… or pk_live_…)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxx
# Convex deployment URL (https://<deployment>.convex.cloud)
VITE_CONVEX_URL=https://your-deployment.convex.cloud
# Stripe publishable key (pk_test_… or pk_live_…)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
# Optional: external OCR endpoint for logbook scans (leave unset to use Claude vision)
VITE_LOGBOOK_OCR_ENDPOINT=
VITE_LOGBOOK_OCR_API_KEY=

# --- Vercel serverless functions (api/*.ts) ----------------------------------
# Set these in the Vercel project, NOT in this committed file.
# ANTHROPIC_API_KEY=sk-ant-xxx
# OPENAI_API_KEY=sk-xxx        # only if OpenAI-backed endpoints are enabled

# =============================================================================
# Convex backend env (set with: npx convex env set NAME value)
# These are NOT read from this file — listed here as the authoritative checklist.
# =============================================================================
# Auth:
#   CLERK_JWT_ISSUER_DOMAIN=https://your-app.clerk.accounts.dev
# AI:
#   ANTHROPIC_API_KEY=sk-ant-xxx           (must ALSO be set in Vercel)
# Embeddings (RAG / library search):
#   EMBEDDING_PROVIDER=voyage              (voyage | openai)
#   VOYAGE_API_KEY=pa-xxx
#   VOYAGE_EMBEDDING_MODEL=voyage-3
#   OPENAI_API_KEY=sk-xxx                  (if EMBEDDING_PROVIDER=openai)
#   OPENAI_EMBEDDING_MODEL=text-embedding-3-large
#   EMBEDDING_DIMENSIONS=1024
# Stripe (live mode for production):
#   STRIPE_SECRET_KEY=sk_live_xxx
#   STRIPE_WEBHOOK_SECRET=whsec_xxx        (webhook -> https://<deployment>.convex.site/stripe-webhook)
#   STRIPE_PRICE_BASIC_MONTHLY=price_xxx
#   STRIPE_PRICE_PRO_MONTHLY=price_xxx
#   STRIPE_PRICE_ENTERPRISE_MONTHLY=price_xxx
#   STRIPE_TRIAL_PERIOD_DAYS=14            (0 or unset = no trial)
# Billing enforcement (OFF for launch — early users grandfathered):
#   BILLING_ENFORCEMENT_ENABLED=false
