{
  "name": "aviation-assessment-analyzer",
  "version": "1.0.0",
  "description": "Aviation Quality Assessment Analysis Tool with Claude AI",
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:unit:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:auth:save": "node scripts/run-playwright-auth-save.js",
    "test:menu-audit": "playwright test tests/menu-organization.spec.ts --project=chromium-with-auth",
    "dev": "npm run predev && vite",
    "predev": "node scripts/check-convex-env.js",
    "setup": "node scripts/setup.js",
    "check:convex": "node scripts/check-convex-env.js",
    "check:embedding-env": "node scripts/check-embedding-env.js",
    "backup:git:mirror": "node scripts/backup-git-mirror.mjs",
    "backup:git:verify": "node scripts/verify-git-mirror.mjs",
    "backup:git:run": "npm run backup:git:mirror && npm run backup:git:verify",
    "dct:list-mdb": "node scripts/dct-from-access/list-mdb-tables.mjs",
    "dct:export-mdb": "node scripts/dct-from-access/export-mdb-to-dct-bundle.mjs",
    "deploy:convex": "npx convex deploy --yes",
    "seo:sitemap:generate": "node scripts/generate-sitemap.mjs",
    "seo:sitemap:check": "node scripts/generate-sitemap.mjs --check",
    "seo:prerender": "node scripts/prerender-seo-pages.mjs",
    "build": "npm run seo:sitemap:generate && tsc && vite build && npm run seo:prerender",
    "preview": "vite preview"
  },
  "keywords": [
    "aviation",
    "quality",
    "assessment",
    "claude",
    "web"
  ],
  "author": "Aviation Quality Company",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "@clerk/backend": "^2.31.0",
    "@clerk/clerk-react": "^5.60.0",
    "@hookform/resolvers": "^5.4.0",
    "@sentry/react": "^10.57.0",
    "@stripe/react-stripe-js": "^6.4.0",
    "@stripe/stripe-js": "^9.6.0",
    "@tanstack/react-table": "^8.21.3",
    "cmdk": "^1.1.1",
    "convex": "^1.31.7",
    "docx": "^9.5.1",
    "mammoth": "^1.11.0",
    "openai": "^4.104.0",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^5.4.624",
    "posthog-js": "^1.383.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-dropzone": "^14.2.3",
    "react-hook-form": "^7.78.0",
    "react-icons": "^5.0.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.0",
    "recharts": "^3.8.0",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "stripe": "^22.1.1",
    "zod": "^3.25.76",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.11.5",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^4.1.0",
    "autoprefixer": "^10.4.17",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^15.15.0",
    "jsdom": "^28.1.0",
    "mdb-reader": "^3.2.0",
    "postcss": "^8.4.33",
    "prettier": "^3.8.3",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.60.1",
    "vite": "^5.0.12",
    "vitest": "^4.1.0"
  }
}
